# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in the values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
APP_PORT=4000
FRONTEND_URL=http://localhost:3000

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/blood_bank_db
MONGODB_USER=your_mongodb_user
MONGODB_PASSWORD=your_mongodb_password

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your_jwt_secret_key_change_in_production_12345
JWT_EXPIRE=7d
ADMIN_JWT_SECRET=your_admin_jwt_secret_key_change_in_production_12345

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Option 1: Firebase Service Account Key as JSON string (recommended)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Option 2: Firebase Service Account Key as file path
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_MESSAGING_SENDER_ID=your-sender-id

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=info
LOG_DIR=./logs

# ============================================
# EMAIL CONFIGURATION (Optional - for OTP)
# ============================================
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# ============================================
# OTP CONFIGURATION
# ============================================
OTP_EXPIRATION=10 # minutes
OTP_MAX_ATTEMPTS=5

# ============================================
# SOCKET.IO CONFIGURATION
# ============================================
SOCKET_CORS_ORIGIN=http://localhost:3000
SOCKET_PING_INTERVAL=25000
SOCKET_PING_TIMEOUT=60000

# ============================================
# SESSION CONFIGURATION
# ============================================
SESSION_SECRET=your_session_secret_change_in_production_12345

# ============================================
# SENTRY ERROR TRACKING
# ============================================
SENTRY_DSN=https://your_key@sentry.io/your_project_id
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0
SENTRY_TRACE_SAMPLE_RATE=0.1

# ============================================
# API DOCUMENTATION
# ============================================
API_DOMAIN=api.bloodconnect.com

# ============================================
# REACT APP CONFIGURATION (Used by CORS)
# ============================================
REACT_APP_URL=https://bloodconnect.com

# ============================================
# PRODUCTION SETTINGS
# ============================================
PRODUCTION_API_URL=https://api.bloodconnect.com
PRODUCTION_FRONTEND_URL=https://bloodconnect.com
