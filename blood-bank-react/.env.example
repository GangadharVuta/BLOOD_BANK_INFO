# Copy this file to .env and replace the placeholder with your API key
# Required for NearbyBloodBanks component to call Google APIs
REACT_APP_GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# Backend API URL for blood bank data
REACT_APP_BACKEND_URL=http://localhost:5000

# 4. Create an API key and restrict it appropriately (HTTP referrers for dev: http://localhost:3000)
# 5. Save the key above and restart the React dev server
